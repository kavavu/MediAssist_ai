# MediAssist AI Environment Configuration
# Copy this file to .env and fill in your actual values

# OpenAI API Key - Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: OpenAI Model (default: gpt-4o-mini)
# Other options: gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Flask Secret (change in production)
SECRET_KEY=dev-secret-key-change-me

# JWT Secret (change in production)
JWT_SECRET_KEY=dev-jwt-secret-key-change-me

# -------------------------------------------------
# M-PESA DARAJA API CONFIGURATION (Sandbox)
# -------------------------------------------------
MPESA_CONSUMER_KEY=your-consumer-key-here
MPESA_CONSUMER_SECRET=your-consumer-secret-here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-ngrok-or-domain/api/payments/mpesa/callback
MPESA_ENV=sandbox

# Demo mode: ALWAYS charges KSh 1 regardless of displayed price (safe for demos)
DEMO_PAYMENT_MODE=true

# Default phone number for STK push demos (your Safaricom-registered number)
# Format: 2547XXXXXXXX
MPESA_DEFAULT_PHONE=254712345678
